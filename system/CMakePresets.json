{
    "version": 2,
    "configurePresets": [
        {
            "name": "default",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
                },
                "CMAKE_PREFIX_PATH": {
                    "type": "STRING",
                    "value": "$env{VCPKG_ROOT}/installed/$env{VCPKG_TARGET_TRIPLET}"
                }
            }
        },
        {
            "name": "wsl2",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
                },
                "CMAKE_PREFIX_PATH": {
                    "type": "STRING",
                    "value": "$env{VCPKG_DIR}/x64-linux-dynamic"
                },
                "RdKafka_DIR": {
                    "type": "STRING",
                    "value": "$env{VCPKG_DIR}/x64-linux-dynamic/share/rdkafka"
                },
                "msgpack_DIR": {
                    "type": "STRING",
                    "value": "$env{VCPKG_DIR}/x64-linux-dynamic/share/msgpack-cxx"
                },
                "glm_DIR": {
                    "type": "STRING",
                    "value": "$env{VCPKG_DIR}/x64-linux-dynamic/share/glm"
                },
                "LZ4_DIR": {
                    "type": "STRING",
                    "value": "$env{VCPKG_DIR}/x64-linux-dynamic/share/lz4"
                }
            }
        },
        {
            "name": "windows",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
                },
                "CMAKE_PREFIX_PATH": {
                    "type": "STRING",
                    "value": "$env{VCPKG_ROOT}/installed/$env{VCPKG_TARGET_TRIPLET}"
                }
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "wsl2",
            "configurePreset": "wsl2"
        }
    ]
}
